// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  TRIAL
  PRO
}

enum MudancaStatus {
  RASCUNHO
  COTANDO
  CONFIRMADA
  CONCLUIDA
}

// ─── Auth.js / next-auth models ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Subscription / plan
  plan                    Plan      @default(FREE)
  trialEndsAt             DateTime?
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   @unique
  stripePriceId           String?
  stripeCurrentPeriodEnd  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts  Account[]
  sessions  Session[]
  mudancas  Mudanca[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Application models ───────────────────────────────────────────────────────

model Item {
  id              String   @id @default(cuid())
  nome            String
  categoria       String   // quarto, cozinha, sala, escritorio, caixas
  iconeUrl        String?  @map("icone_url")
  larguraCm       Int      @map("largura_cm")
  alturaCm        Int      @map("altura_cm")
  profundidadeCm  Int      @map("profundidade_cm")
  pesoKg          Float    @map("peso_kg")
  volumeM3        Float    @map("volume_m3")
  createdAt       DateTime @default(now()) @map("created_at")

  mudancaItens    MudancaItem[]

  @@map("items")
}

model Caminhao {
  id              String   @id @default(cuid())
  nome            String
  tipo            String   // fiorino, hr, tres_quartos, bau
  capacidadeM3    Float    @map("capacidade_m3")
  capacidadeKg    Float    @map("capacidade_kg")
  comprimentoCm   Int      @map("comprimento_cm")
  larguraCm       Int      @map("largura_cm")
  alturaCm        Int      @map("altura_cm")
  imagemUrl       String?  @map("imagem_url")
  createdAt       DateTime @default(now()) @map("created_at")

  mudancas        Mudanca[]
  cargaLayouts    CargaLayout[]

  @@map("caminhoes")
}

model Transportadora {
  id              String   @id @default(cuid())
  nome            String
  logoUrl         String?  @map("logo_url")
  notaMedia       Float    @default(0) @map("nota_media")
  totalAvaliacoes Int      @default(0) @map("total_avaliacoes")
  cidade          String
  tiposCaminhao   String[] @map("tipos_caminhao")
  createdAt       DateTime @default(now()) @map("created_at")

  cotacoes        Cotacao[]

  @@map("transportadoras")
}

model Mudanca {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  enderecoOrigem  String   @map("endereco_origem")
  enderecoDestino String   @map("endereco_destino")
  dataDesejada    DateTime? @map("data_desejada")
  caminhaoId      String?  @map("caminhao_id")
  status          MudancaStatus @default(RASCUNHO)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caminhao        Caminhao? @relation(fields: [caminhaoId], references: [id])
  itens           MudancaItem[]
  cotacoes        Cotacao[]
  cargaLayout     CargaLayout?

  @@map("mudancas")
}

model MudancaItem {
  id         String   @id @default(cuid())
  mudancaId  String   @map("mudanca_id")
  itemId     String   @map("item_id")
  quantidade Int      @default(1)

  mudanca    Mudanca  @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  item       Item     @relation(fields: [itemId], references: [id])

  @@map("mudanca_itens")
}

model CargaLayout {
  id                   String   @id @default(cuid())
  mudancaId            String   @unique @map("mudanca_id")
  caminhaoId           String   @map("caminhao_id")
  itensPosicionados    Json     @map("itens_posicionados") // [{itemId, x, y, rotacao}]
  ocupacaoPercentual   Float    @map("ocupacao_percentual")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  mudanca              Mudanca  @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  caminhao             Caminhao @relation(fields: [caminhaoId], references: [id])

  @@map("carga_layouts")
}

model Cotacao {
  id               String   @id @default(cuid())
  mudancaId        String   @map("mudanca_id")
  transportadoraId String   @map("transportadora_id")
  precoCentavos    Int      @map("preco_centavos")
  dataDisponivel   DateTime @map("data_disponivel")
  seguroIncluso    Boolean  @default(false) @map("seguro_incluso")
  validade         DateTime
  createdAt        DateTime @default(now()) @map("created_at")

  mudanca          Mudanca        @relation(fields: [mudancaId], references: [id], onDelete: Cascade)
  transportadora   Transportadora @relation(fields: [transportadoraId], references: [id])

  @@map("cotacoes")
}
